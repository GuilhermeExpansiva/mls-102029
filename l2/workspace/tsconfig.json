{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmitOnError": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "/_102033_/core/*": ["_102033_/core/*"],
      "/_102033_/l2/*": ["_102033_/l2/*"],
      "/_102034_/l1/*": ["_102034_/l1/*"],
      "/_102034_/l2/*": ["_102034_/l2/*"],
      "/_102029_/l2/*": ["_102029_/l2/*"],
      "/_102030_/l1/*": ["_102030_/l1/*"],
      "/_102030_/l2/*": ["_102030_/l2/*"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "_102033_/core/**/*.d.ts",
    "_102033_/core/**/*.ts",
    "_102033_/l2/**/*.d.ts",
    "_102033_/l2/**/*.ts",
    "_102034_/l1/**/*.ts",
    "_102034_/l2/**/*.d.ts",
    "_102034_/l2/**/*.ts",
    "_102029_/l2/**/*.d.ts",
    "_102029_/l2/**/*.ts",
    "_102030_/l1/**/*.ts",
    "_102030_/l2/**/*.d.ts",
    "_102030_/l2/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "_102030_/types/**/*.d.ts"
  ]
}
